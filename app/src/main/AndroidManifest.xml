<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".application.SmallbeeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Smallbee"
        tools:targetApi="31">
        <activity
            android:name=".activity.MultiRecyclerViewActivity"
            android:exported="false" />
        <activity
            android:name=".activity.BinderStubActivity"
            android:exported="false" />
        <activity
            android:name=".activity.ViewPagerActivity"
            android:exported="false" />
        <activity
            android:name=".activity.BindingRecyclerviewActivity"
            android:exported="false" />
        <activity
            android:name=".activity.CoordinatorLayoutActivity"
            android:exported="false" />
        <activity
            android:name=".activity.DatabindingActivity"
            android:exported="false" />
        <activity
            android:name=".activity.TestActivity"
            android:exported="false" />
        <activity
            android:name=".activity.MainActivity"
            android:exported="false"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".activity.MessageCenterActivity"
            android:exported="false"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".activity.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>