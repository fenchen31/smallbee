<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@null">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_conners20_solidffffff"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_horizontal"
                android:text="@string/welcome_to_use_smallbee"
                android:textColor="@color/color_000000"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="15sp"
                android:layout_marginEnd="15dp"
                android:maxHeight="250dp"
                android:paddingTop="15dp"
                app:layout_constraintHeight_max="250dp"
                app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

            <View
                android:id="@+id/view_cover"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:background="@drawable/shape_gradinet_00ffffff_ffffffff"
                app:layout_constraintBottom_toBottomOf="@id/rv_privacy"
                app:layout_constraintEnd_toEndOf="@id/rv_privacy"
                app:layout_constraintStart_toStartOf="@id/rv_privacy" />

            <Button
                android:id="@+id/bt_agree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="50dp"
                android:background="@drawable/shape_conners20_solidd12424"
                android:minHeight="0dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="@string/agree"
                android:textColor="@color/color_FFFFFF"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_privacy" />

            <Button
                android:id="@+id/bt_do_not_agree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="50dp"
                android:background="@drawable/shape_conners20_solidd12424"
                android:minHeight="0dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="@string/do_not_agree_and_exit"
                android:textColor="@color/color_FFFFFF"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bt_agree" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</layout>