<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_conners20_solidffffff"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tv_welcome"
            android:textSize="18sp"
            android:textColor="@color/color_000000"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:text="@string/welcome_to_use_smallbee" />

        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome"
            android:layout_marginStart="15sp"
            android:id="@+id/rv_privacy"
            android:maxHeight="250dp"
            app:layout_constraintHeight_max="250dp"
            android:layout_marginEnd="15dp" />
        <View
            android:layout_width="0dp"
            android:layout_height="10dp"
            app:layout_constraintStart_toStartOf="@id/rv_privacy"
            app:layout_constraintEnd_toEndOf="@id/rv_privacy"
            app:layout_constraintBottom_toBottomOf="@id/rv_privacy"
            android:background="@drawable/shape_gradinet_00ffffff_ffffffff"/>
        <Button
            style="@style/smallbeeButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agree"
            android:id="@+id/btn_agree"
            android:textSize="20sp"
            android:textColor="@color/color_FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/rv_privacy"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:layout_marginStart="50dp"
            android:layout_marginEnd="50dp"
            android:background="@drawable/shape_conners20_solidd12424" />

        <Button
            style="@style/smallbeeButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/do_not_agree_and_exit"
            android:id="@+id/btn_do_not_agree"
            android:textSize="20sp"
            android:textColor="@color/color_FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/btn_agree"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="20dp"
            android:layout_marginStart="50dp"
            android:layout_marginEnd="50dp"
            android:background="@drawable/shape_conners20_solidd12424"
            android:paddingBottom="20dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>