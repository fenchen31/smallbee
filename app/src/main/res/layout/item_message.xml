<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:gravity="center_vertical"
        android:paddingTop="10dp"
        android:layout_height="104dp">

        <CheckBox
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:id="@+id/cb_select"
            android:focusable="false"
            android:clickable="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:background="@color/color_FFFFFF"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tv_result"
                android:textSize="24sp"
                android:textColor="@color/color_6E6F6E"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textStyle="bold"
                android:lines="1"
                android:maxEms="15"
                android:ellipsize="end"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="10dp"
                tools:text="应用审核不通过"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="13dp" />

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/shape_radius25_colorf44336"
                android:id="@+id/view_red_point"
                android:visibility="invisible"
                tools:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_result"
                android:layout_marginStart="8dp"
                android:layout_marginTop="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:lines="1"
                android:ellipsize="end"
                android:id="@+id/tv_detail"
                android:textColor="@color/color_000000"
                android:textSize="24sp"
                app:layout_constraintEnd_toStartOf="@id/iv_more"
                app:layout_constraintStart_toEndOf="@id/view_red_point"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="2021-05-05 10:10:10"
                android:layout_marginEnd="30dp" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:paddingTop="21dp"
                android:paddingBottom="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@mipmap/img_1"
                android:paddingEnd="30dp"
                android:id="@+id/iv_more" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</layout>