<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="event"
            type="com.practice.smallbee.event.MediaSessionEvent" />
        <variable
            name="vm"
            type="com.practice.smallbee.viewmodel.MediaSessionVM" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activity.MediaSessionActivity">
        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:layout_constraintTop_toTopOf="parent"
            android:text="@string/get_media_info"
            android:onClick="@{() -> event.clickGetMediaInfo(vm)}"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            android:padding="15dp"
            android:textSize="20sp"
            android:textColor="@color/color_000000"
            android:gravity="center"
            android:text="@{vm.mediaInfo.toString()}"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>