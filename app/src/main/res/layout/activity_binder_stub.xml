<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="event"
            type="com.practice.smallbee.event.BinderStubActivityEvent" />
        <variable
            name="viewmodel"
            type="com.practice.smallbee.viewmodel.BinderStubViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activity.BinderStubActivity">
        <Button
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="@string/send_data"
            android:onClick="@{v-> event.sendData()}"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@color/color_6E6F6E"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>