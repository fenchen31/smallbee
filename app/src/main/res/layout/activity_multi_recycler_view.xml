<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activity.MultiRecyclerViewActivity">
        <LinearLayout
            android:id="@+id/ll_game"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            android:gravity="center">
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/color_FFFFFF"
                android:text="增加10个游戏数据"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_game_increase"/>
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="删除game10个游戏数据"
                android:background="@color/color_8BC34A"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_game_delete"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/color_FFFFFF"
                android:text="无数据"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_empty"/>
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="增加10个流量数据"
                android:background="@color/color_8BC34A"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_traffic_increase"/>
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/color_FFFFFF"
                android:text="删除游戏10个数据"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_traffic_delete"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ll_simple"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            android:gravity="center">
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/color_FFFFFF"
                android:text="增加10个数据"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_increase"/>
            <Button
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="删除10个数据"
                android:background="@color/color_8BC34A"
                android:textColor="@color/color_000000"
                android:id="@+id/bt_delete"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            android:id="@+id/rv_content" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>