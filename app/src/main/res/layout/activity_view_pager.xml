<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="adapter"
            type="com.practice.smallbee.adapter.ViewPagerAdapter" />
        <variable
            name="viewmodel"
            type="com.practice.smallbee.viewmodel.ViewPagerViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activity.ViewPagerActivity">

        <androidx.viewpager2.widget.ViewPager2
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:id="@+id/vp_image"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            adapter="@{adapter}"
            android:orientation="horizontal" />
        <com.google.android.material.tabs.TabLayout
            android:layout_width="wrap_content"
            android:layout_height="10dp"
            android:id="@+id/tl_indicator"
            app:tabGravity="center"
            app:tabMaxWidth="10dp"
            app:tabIndicatorHeight="0dp"
            app:tabIndicator="@drawable/select_indicator"
            android:layout_marginTop="10dp"
            android:background="@color/color_FFC107"
            app:layout_constraintTop_toBottomOf="@id/vp_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/color_4CAF50"
            android:text="@string/change_data"
            android:gravity="center"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="50dp"
            android:onClickListener="@{view -> viewmodel.changeData()}"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>