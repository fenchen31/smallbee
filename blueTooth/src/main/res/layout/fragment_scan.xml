<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View"/>
        <variable
            name="vm"
            type="com.practice.bluetooth.viewmodel.ScanViewModel" />
        <variable
            name="event"
            type="com.practice.bluetooth.event.ScanEvent" />
        <variable
            name="adapter"
            type="com.practice.bluetooth.adapter.DeviceAdapter" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="com.practice.bluetooth.fragment.ScanFragment">


        <Button
            android:id="@+id/bt_start"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="5dp"
            android:text="@string/start_scan"
            android:visibility="@{vm.showLoading ? View.INVISIBLE : View.VISIBLE}"
            android:backgroundTint="@color/color_6E6F6E"
            android:onClick="@{() -> event.startScan(vm)}"
            android:textColor="@color/color_000000"
            android:textSize="20sp"/>

        <ProgressBar
            android:layout_width="0dp"
            android:layout_height="0dp"
            style="?attr/progressBarStyle"
            app:layout_constraintStart_toStartOf="@id/bt_start"
            app:layout_constraintEnd_toEndOf="@id/bt_start"
            app:layout_constraintTop_toTopOf="@id/bt_start"
            app:layout_constraintBottom_toBottomOf="@id/bt_start"
            android:visibility="@{vm.showLoading ? View.VISIBLE : View.GONE}"/>

        <Button
            android:id="@+id/bt_stop"
            app:layout_constraintTop_toBottomOf="@id/bt_start"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/color_4CAF50"
            android:layout_margin="5dp"
            android:text="@string/stop_scan"
            android:onClick="@{() -> event.stopScan(vm)}"
            android:textColor="@color/color_000000"

            android:textSize="20sp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:adapter="@{adapter}"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/bt_stop"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>