<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.practice.bluetooth.viewmodel.WriteDataVM" />
        <variable
            name="event"
            type="com.practice.bluetooth.event.WriteDataEvent" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="com.practice.bluetooth.fragment.WriteDataFragment">
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="15dp"
            android:layout_marginTop="50dp"
            android:textColor="@color/color_000000"
            android:textSize="22sp"
            android:background="@drawable/bg_send_edit"
            android:id="@+id/et_send"
            android:text="@={vm.inputText}"/>
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/send"
            android:textSize="20sp"
            android:textColor="@color/color_000000"
            android:layout_margin="10dp"
            android:background="@drawable/bg_send_btn"
            app:layout_constraintBottom_toTopOf="@id/gl_landspace50"
            android:onClick="@{() -> event.sendData(vm.inputText)}"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/color_000000"
            android:textSize="15sp"
            android:gravity="center"
            android:id="@+id/tv_received_title"
            app:layout_constraintTop_toBottomOf="@id/gl_landspace50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/gl_portrait50"
            android:text="@string/received_data" />
        <TextView
            android:layout_width="0dp"
            android:layout_margin="10dp"
            android:layout_height="0dp"
            android:background="@color/color_4CAF50"
            android:textColor="@color/color_DB3A3A"
            app:layout_constraintTop_toBottomOf="@id/tv_received_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/gl_portrait50"
            android:text="@{vm.receiveData}" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/color_000000"
            android:textSize="15sp"
            android:gravity="center"
            android:id="@+id/tv_sended_title"
            app:layout_constraintTop_toBottomOf="@id/gl_landspace50"
            app:layout_constraintStart_toStartOf="@id/gl_portrait50"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="@string/sended_data" />
        <TextView
            android:layout_width="0dp"
            android:layout_margin="10dp"
            android:layout_height="0dp"
            android:background="@color/color_2196F3"
            android:textColor="@color/color_000000"
            app:layout_constraintTop_toBottomOf="@id/tv_received_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/gl_portrait50"
            android:text="@{vm.sendData}" />
        <androidx.constraintlayout.widget.Guideline
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintGuide_percent="0.5"
            android:orientation="horizontal"
            android:id="@+id/gl_landspace50"/>
        <androidx.constraintlayout.widget.Guideline
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/gl_landspace50"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_percent="0.5"
            android:orientation="vertical"
            android:id="@+id/gl_portrait50"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>